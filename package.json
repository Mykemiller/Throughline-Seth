{
  "name": "throughline",
  "private": true,
  "version": "0.0.0",
  "description": "Throughline — multi-product family-history platform (web prototype).",
  "workspaces": [
    "packages/*",
    "server",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server & npm run dev --workspace apps/web",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace apps/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspace apps/web && node scripts/build-vercel.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
