# Throughline — First Thread voice runtime (THOUG-129)
# Copy to .env and fill in. NEVER commit a real .env. All secrets are read from
# the environment at runtime; if a required var is missing the server stops and
# tells you which one.

# ── Feature flag ──────────────────────────────────────────────────────────────
# The entire voice runtime ships behind this flag. Off by default.
# Server reads FIRST_THREAD_VOICE; web reads VITE_FIRST_THREAD_VOICE.
FIRST_THREAD_VOICE=false
VITE_FIRST_THREAD_VOICE=false

# ── Hume EVI 3 (transport, STT, prosody, turn-taking, TTS) ────────────────────
# ZDR must be enabled on this Hume config (see docs/zdr-verification.md).
# The BYO-LLM "custom language model" on this config must point at the server's
# /api/clm/chat/completions endpoint.
HUME_API_KEY=
HUME_SECRET_KEY=
HUME_CONFIG_ID=
# Exposed to the browser so it can select the ZDR + BYO-LLM config when it opens
# the EVI socket. This is a non-secret config id, not a key.
VITE_HUME_CONFIG_ID=

# ── Anthropic (Claude as the BYO-LLM) ─────────────────────────────────────────
# Org must have ZDR/owner-voice gating in place per THOUG-99/THOUG-100.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-opus-4-8.
CLAUDE_MODEL=claude-opus-4-8

# ── Supabase (single source of truth; migration 005 is live) ──────────────────
SUPABASE_URL=
# Service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Owner-voice test gate ─────────────────────────────────────────────────────
# rot_capture_sessions.subscriber_id is NOT NULL. For THOUG-129 we build and
# spike on the OWNER's own subscriber row only — no real-subscriber audio until
# the Hume DPA (THOUG-99) closes. Set this to your own subscribers.subscriber_id.
OWNER_SUBSCRIBER_ID=

# ── Local dev wiring ──────────────────────────────────────────────────────────
PORT=8787
# Where the browser reaches the server (Vite dev proxies /api here too).
VITE_SERVER_ORIGIN=http://localhost:8787

# ── Photo ingest (E13-05/06) ──────────────────────────────────────────────────
# Private Storage bucket for EXIF-stripped photo derivatives (+ opt-in
# originals). Created automatically if missing. Optional; defaults shown.
SUPABASE_PHOTO_BUCKET=first-thread-photos
